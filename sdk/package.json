{
  "name": "hsk-passport-sdk",
  "version": "1.1.0",
  "description": "TypeScript SDK for HSK Passport — privacy-preserving ZK credentials on HashKey Chain. Add KYC verification to your dApp without exposing personal data on-chain.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ridwannurudeen/hsk-passport.git",
    "directory": "sdk"
  },
  "homepage": "https://hskpassport.gudman.xyz",
  "bugs": {
    "url": "https://github.com/Ridwannurudeen/hsk-passport/issues"
  },
  "keywords": [
    "zk",
    "zero-knowledge",
    "zkp",
    "credentials",
    "kyc",
    "privacy",
    "hashkey",
    "hashkey-chain",
    "semaphore",
    "groth16",
    "ethereum",
    "compliance",
    "rwa",
    "identity",
    "verifiable-credentials"
  ],
  "license": "MIT",
  "author": "HSK Passport Team",
  "dependencies": {
    "@semaphore-protocol/group": "^4.14.2",
    "@semaphore-protocol/identity": "^4.14.2",
    "@semaphore-protocol/proof": "^4.14.2",
    "ethers": "^6.13.0",
    "poseidon-lite": "^0.3.0",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.5.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
